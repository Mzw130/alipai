{
  "expo": {
    "name": "ClipAI",
    "slug": "clipai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FAF7F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.clipai.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F5"
      },
      "package": "com.clipai.app"
    },
    "plugins": [
      "expo-image-picker",
      "expo-asset",
      "expo-font"
    ]
  }
}
